---
import { renderKeyboard, type ThemeColors } from '../scripts/keyboard-renderer';
import defaultLayout from '../data/default-layout.json';

interface Props {
  colors: ThemeColors;
  isDark?: boolean;
}

const { colors, isDark = false } = Astro.props;
const layout = defaultLayout.default;
const html = renderKeyboard(colors, layout, {
  keyHGap: 6,
  keyVGap: 6,
  keyRadius: 10,
  borderEnabled: false,
  isDark,
});
---
<Fragment set:html={html} />
