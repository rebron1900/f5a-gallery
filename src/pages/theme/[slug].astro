---
import Layout from '../../layouts/Layout.astro';
import KeyboardPreview from '../../components/KeyboardPreview.astro';
import { readdirSync, readFileSync } from 'fs';
import { join } from 'path';

export async function getStaticPaths() {
  const themesDir = join(process.cwd(), 'src/content/themes');
  const files = readdirSync(themesDir).filter(f => f.endsWith('.json'));

  return files.map(f => {
    const slug = f.replace('.json', '');
    const data = JSON.parse(readFileSync(join(themesDir, f), 'utf-8'));
    return { params: { slug }, props: { theme: data, slug } } as const;
  });
}

const { theme, slug } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

function int32ToCSS(n: number): string {
  const u = n >= 0 ? n : n + 0x100000000;
  return '#' + ((u >> 16) & 0xff).toString(16).padStart(2, '0') + ((u >> 8) & 0xff).toString(16).padStart(2, '0') + (u & 0xff).toString(16).padStart(2, '0');
}

const colorLabels: Record<string, string> = {
  backgroundColor: '背景',
  barColor: '工具栏',
  keyboardColor: '键盘底色',
  keyBackgroundColor: '按键背景',
  keyTextColor: '按键文字',
  candidateTextColor: '候选文字',
  candidateLabelColor: '候选标签',
  candidateCommentColor: '候选注释',
  altKeyBackgroundColor: '功能键背景',
  altKeyTextColor: '功能键文字',
  accentKeyBackgroundColor: '强调键背景',
  accentKeyTextColor: '强调键文字',
  keyPressHighlightColor: '按压高亮',
  keyShadowColor: '按键阴影',
  popupBackgroundColor: '弹出背景',
  popupTextColor: '弹出文字',
  spaceBarColor: '空格键',
  dividerColor: '分割线',
  clipboardEntryColor: '剪贴板项',
  genericActiveBackgroundColor: '激活态背景',
  genericActiveForegroundColor: '激活态文字',
};
---
<Layout title={theme.name}>
  <div class="container detail-page">

    <!-- Theme Header -->
    <div class="detail-header">
      <h1>{theme.name}</h1>
      <div class="detail-meta">
        <span>@{theme.author}</span>
        {theme.builtin && <span class="builtin-badge">内置</span>}
        <span class="detail-mode">{theme.isDark ? '暗色' : '亮色'}</span>
      </div>
      <div class="detail-actions">
        <button class="btn" id="copy-json">复制 JSON</button>
        <button class="btn" id="download-json">下载 ZIP</button>
        <button class="btn btn-primary" id="show-qr">扫码导入</button>
      </div>
    </div>

    <!-- Keyboard Preview -->
    <div class="detail-preview">
      <KeyboardPreview colors={theme} />
    </div>

    <!-- Color Preview Grid -->
    <div class="color-section">
      <h2>颜色预览</h2>
      <div class="color-grid">
        {Object.keys(colorLabels).filter(key => theme[key] !== undefined).map(key => (
          <div class="color-item">
            <div class="color-swatch" style={`background:${int32ToCSS(theme[key])}`}></div>
            <div>
              <div class="color-label">{colorLabels[key]}</div>
              <div class="color-value">{int32ToCSS(theme[key])}</div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Theme Info -->
    <div class="theme-info-section">
      <h2>主题信息</h2>
      <div class="theme-info-grid">
        <div class="theme-info-row">
          <span class="theme-info-label">模式</span>
          <span class="theme-info-value">{theme.isDark ? '暗色 (Dark)' : '亮色 (Light)'}</span>
        </div>
        <div class="theme-info-row">
          <span class="theme-info-label">格式版本</span>
          <span class="theme-info-value">{theme.version || '2.1'}</span>
        </div>
        <div class="theme-info-row">
          <span class="theme-info-label">颜色数量</span>
          <span class="theme-info-value">{Object.keys(colorLabels).length} 个 token</span>
        </div>
      </div>
    </div>

    <!-- CTA -->
    <div class="detail-cta">
      <a href={`https://github.com/rebron1900/f5a-gallery/blob/main/src/content/themes/${slug}.json`} target="_blank" class="btn btn-primary btn-lg">
        在 fcitx5-android-fx（靓企鹅版）中使用
      </a>
    </div>

    <!-- QR Modal -->
    <div class="qr-modal" id="qr-modal" style="display:none;">
      <div class="qr-modal-content">
        <button class="qr-modal-close" id="qr-modal-close" aria-label="关闭">✕</button>
        <h3>扫码导入主题</h3>
        <p>使用靓企鹅扫描下方二维码</p>
        <div class="qr-code" id="qr-code"></div>
        <p class="qr-filename" id="qr-filename"></p>
      </div>
    </div>

  </div>

    <!-- ===== Footer ===== -->
    <footer class="site-footer">
      <div class="footer-grid">
        <div class="footer-col">
          <h3>关于 靓企鹅主题商店</h3>
          <p>开源的 fcitx5-android-fx（靓企鹅版）键盘主题商店，由社区驱动，自动化部署。</p>
          <a href="https://github.com/rebron1900/f5a-gallery" target="_blank">GitHub 仓库 →</a>
        </div>
        <div class="footer-col">
          <h3>快速链接</h3>
          <ul>
            <li><a href={base + '/contributing'}>主题提交指南</a></li>
            <li><a href={base + '/contributing'}>JSON 格式说明</a></li>
            <li><a href={base + '/contributing'}>贡献指南</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h3>技术栈</h3>
          <ul>
            <li>Astro SSG</li>
            <li>GitHub Actions</li>
            <li>GitHub Pages</li>
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg> 靓企鹅主题商店
      </div>
    </footer>

  <script define:vars={{ theme, slug, base }}>
    document.getElementById('copy-json').addEventListener('click', function() {
      var json = JSON.stringify(theme, null, 2);
      navigator.clipboard.writeText(json).then(function() {
        var btn = document.getElementById('copy-json');
        btn.textContent = '已复制';
        setTimeout(function() { btn.textContent = '复制 JSON'; }, 2000);
      }).catch(function() {
        var ta = document.createElement('textarea');
        ta.value = json;
        ta.style.position = 'fixed';
        ta.style.opacity = '0';
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        document.body.removeChild(ta);
        var btn = document.getElementById('copy-json');
        btn.textContent = '已复制';
        setTimeout(function() { btn.textContent = '复制 JSON'; }, 2000);
      });
    });

    document.getElementById('download-json').addEventListener('click', function() {
      if (typeof JSZip === 'undefined') return;
      var json = JSON.stringify(theme, null, 2);
      var zip = new JSZip();
      zip.file(slug + '.json', json);
      zip.generateAsync({ type: 'blob' }).then(function(blob) {
        var url = URL.createObjectURL(blob);
        var a = document.createElement('a');
        a.href = url;
        a.download = slug + '.zip';
        a.click();
        URL.revokeObjectURL(url);
      });
    });

    // QR code for 靓企鹅 import
    var qrModal = document.getElementById('qr-modal');
    var qrClose = document.getElementById('qr-modal-close');
    var qrCodeEl = document.getElementById('qr-code');
    var qrFilename = document.getElementById('qr-filename');
    var qrDataCache = null;

    document.getElementById('show-qr').addEventListener('click', function() {
      qrModal.style.display = 'flex';
      qrCodeEl.innerHTML = '<p style="color:var(--text-sub)">加载中…</p>';
      qrFilename.textContent = '';

      function renderQr(data) {
        var qrStr = data[slug];
        if (!qrStr) {
          qrCodeEl.innerHTML = '<p style="color:var(--text-sub)">该主题暂无二维码</p>';
          return;
        }
        if (typeof qrcode !== 'undefined') {
          var qr = qrcode(0, 'M');
          qr.addData(qrStr);
          qr.make();
          qrCodeEl.innerHTML = qr.createSvgTag({ cellSize: 4, margin: 4 });
          var svg = qrCodeEl.querySelector('svg');
          if (svg) { svg.setAttribute('width', '100%'); svg.setAttribute('height', '100%'); }
        } else {
          qrCodeEl.innerHTML = '<p style="color:var(--text-sub)">QR 库加载失败</p>';
        }
        qrFilename.textContent = slug + '.json';
      }

      if (qrDataCache) {
        renderQr(qrDataCache);
      } else {
        fetch(base + '/qr-data.json')
          .then(function(r) { return r.json(); })
          .then(function(data) { qrDataCache = data; renderQr(data); })
          .catch(function() { qrCodeEl.innerHTML = '<p style="color:var(--text-sub)">加载失败</p>'; });
      }
    });

    qrClose.addEventListener('click', function() {
      qrModal.style.display = 'none';
    });
    qrModal.addEventListener('click', function(e) {
      if (e.target === qrModal) qrModal.style.display = 'none';
    });
  </script>
  </script>

  <style>
    .detail-page {
      padding: 24px 32px 48px;
    }

    .detail-header {
      text-align: center;
      margin-bottom: 24px;
    }

    .detail-header h1 {
      font-size: 24px;
      font-weight: 700;
      color: var(--text-primary);
      margin-bottom: 8px;
    }

    .detail-meta {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      font-size: 13px;
      color: var(--text-sub);
      margin-bottom: 16px;
    }

    .detail-mode {
      background: var(--green-pale);
      color: var(--green-mid);
      padding: 2px 8px;
      border-radius: 4px;
      font-size: 12px;
      font-weight: 500;
    }

    .detail-actions {
      display: flex;
      gap: 8px;
      justify-content: center;
    }

    .detail-preview {
      max-width: 480px;
      margin: 0 auto 32px;
    }

    /* Theme Info */
    .theme-info-section {
      margin-top: 32px;
    }

    .theme-info-section h2 {
      font-size: 16px;
      font-weight: 600;
      color: var(--text-primary);
      margin-bottom: 12px;
    }

    .theme-info-grid {
      background: var(--bg-white);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      overflow: hidden;
    }

    .theme-info-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 12px 16px;
      border-bottom: 1px solid var(--border);
    }

    .theme-info-row:last-child {
      border-bottom: none;
    }

    .theme-info-label {
      font-size: 13px;
      color: var(--text-sub);
    }

    .theme-info-value {
      font-size: 13px;
      font-weight: 500;
      color: var(--text-primary);
    }

    /* CTA */
    .detail-cta {
      margin-top: 32px;
      text-align: center;
    }

    .btn-lg {
      padding: 14px 32px;
      font-size: 16px;
    }

    /* Mobile */
    @media (max-width: 768px) {
      .detail-page { padding: 16px 16px 32px; }
      .detail-header h1 { font-size: 20px; }
      .detail-actions { flex-direction: column; gap: 8px; }
      .detail-actions .btn { justify-content: center; }
      .color-grid { grid-template-columns: repeat(2, 1fr); }
    }

    @media (max-width: 480px) {
      .color-grid { grid-template-columns: 1fr; }
    }

    /* QR Modal */
    .qr-modal {
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.4);
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 2000;
    }

    .qr-modal-content {
      background: var(--bg-white);
      border-radius: var(--radius-lg);
      padding: 32px;
      text-align: center;
      max-width: 340px;
      width: 90%;
      position: relative;
    }

    .qr-modal-content h3 {
      font-size: 18px;
      font-weight: 600;
      color: var(--text-primary);
      margin-bottom: 4px;
    }

    .qr-modal-content > p {
      font-size: 13px;
      color: var(--text-sub);
      margin-bottom: 20px;
    }

    .qr-code {
      display: flex;
      justify-content: center;
      margin-bottom: 16px;
    }

    .qr-code svg {
      width: 100%;
      height: 100%;
    }

    .qr-filename {
      font-size: 12px;
      color: var(--text-sub);
      font-family: var(--font-mono);
    }

    .qr-modal-close {
      position: absolute;
      top: 12px;
      right: 12px;
      width: 28px;
      height: 28px;
      display: flex;
      align-items: center;
      justify-content: center;
      border: none;
      background: none;
      font-size: 16px;
      color: var(--text-sub);
      cursor: pointer;
      border-radius: var(--radius-sm);
    }

    .qr-modal-close:hover {
      background: var(--bg);
    }
  </style>
</Layout>
