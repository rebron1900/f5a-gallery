---
import Layout from '../layouts/Layout.astro';
import { readdirSync, readFileSync } from 'fs';
import { join } from 'path';

const themesDir = join(process.cwd(), 'src/content/themes');
const files = readdirSync(themesDir).filter(f => f.endsWith('.json'));

const themeMeta: Record<string, { author: string; builtin: boolean; issue?: number }> =
  JSON.parse(readFileSync(join(process.cwd(), 'src/data/theme-meta.json'), 'utf-8'));

interface Theme {
  name: string;
  isDark: boolean;
  [key: string]: any;
}

function int32ToCSS(n: number): string {
  const u = n >= 0 ? n : n + 0x100000000;
  return '#' + ((u >> 16) & 0xff).toString(16).padStart(2, '0') + ((u >> 8) & 0xff).toString(16).padStart(2, '0') + (u & 0xff).toString(16).padStart(2, '0');
}

const themes: { slug: string; theme: Theme }[] = files.map(f => {
  const slug = f.replace('.json', '');
  const data = JSON.parse(readFileSync(join(themesDir, f), 'utf-8'));
  return { slug, theme: data as Theme };
});

const PALETTE_KEYS = ['backgroundColor', 'keyBackgroundColor', 'altKeyBackgroundColor', 'accentKeyBackgroundColor', 'keyTextColor'];
const themesJson = JSON.stringify(Object.fromEntries(themes.map(t => [t.slug, t.theme])));
const layoutData = JSON.parse(readFileSync(join(process.cwd(), 'src/data/default-layout.json'), 'utf-8'));
const layoutJson = JSON.stringify(layoutData.default);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title="我的收藏">
  <div class="container themes-page">

    <div class="themes-page-header">
      <div class="themes-page-title-row">
        <a href={base + '/'} class="back-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
          返回首页
        </a>
      </div>
      <h1>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="color:#f39c12;vertical-align:middle;margin-right:6px;"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        我的收藏
      </h1>
      <p class="themes-page-sub" id="fav-status">登录后查看你收藏的主题</p>
    </div>

    <div id="fav-login-prompt" class="fav-login-prompt" style="display:none;">
      <p>需要 GitHub 登录才能查看收藏</p>
      <button class="btn btn-primary" onclick="loginWithGitHub()">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        GitHub 登录
      </button>
    </div>

    <div id="fav-loading" class="fav-loading" style="display:none;">
      <p>正在加载收藏...</p>
    </div>

    <div id="fav-empty" class="fav-empty" style="display:none;">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--text-sub)" stroke-width="1.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
      <p>还没有收藏的主题</p>
      <a href={`${base}/themes`} class="btn">去浏览主题</a>
    </div>

    <div class="theme-grid" id="fav-grid" style="display:none;"></div>

    <div class="theme-popup" id="theme-popup">
      <button class="theme-popup-close" id="theme-popup-close" aria-label="关闭">✕</button>
      <div class="theme-popup-name" id="theme-popup-name"></div>
      <div class="theme-popup-kb" id="theme-popup-kb"></div>
      <div class="theme-popup-actions">
        <button class="btn btn-sm" id="popup-download">下载 ZIP</button>
        <button class="btn btn-sm" id="popup-copy">复制 JSON</button>
        <button class="btn btn-sm" id="popup-qr">扫码</button>
        <a class="btn btn-primary btn-sm" id="popup-detail" href="#">详情</a>
      </div>
    </div>

    <div class="qr-modal" id="qr-modal" style="display:none;">
      <div class="qr-modal-content">
        <button class="qr-modal-close" id="qr-modal-close" aria-label="关闭">✕</button>
        <h3>扫码导入主题</h3>
        <p>使用小企鹅扫描下方二维码</p>
        <div class="qr-code" id="qr-code"></div>
        <p class="qr-filename" id="qr-filename"></p>
      </div>
    </div>
  </div>

  <script define:vars={{ themesJson, layoutJson, base }}>
    var themes = JSON.parse(themesJson);
    var layout = JSON.parse(layoutJson);
    var API_BASE = 'https://small-rice-5955.me-d1b.workers.dev';

    var PALETTE_KEYS = ['backgroundColor', 'keyBackgroundColor', 'altKeyBackgroundColor', 'accentKeyBackgroundColor', 'keyTextColor'];

    function int32ToCSS(n) {
      var u = n >= 0 ? n : n + 0x100000000;
      return '#' + ((u >> 16) & 0xff).toString(16).padStart(2, '0') + ((u >> 8) & 0xff).toString(16).padStart(2, '0') + (u & 0xff).toString(16).padStart(2, '0');
    }

    function escapeHtml(s) {
      return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }

    function renderCard(slug, theme) {
      var themeMeta = {};
      try { themeMeta = JSON.parse(document.getElementById('fav-grid').dataset.meta || '{}'); } catch(e) {}
      var meta = themeMeta[slug] || {};
      var palette = PALETTE_KEYS.map(function(k) { return int32ToCSS(theme[k]); });
      var swatches = palette.map(function(c) { return '<div class="theme-card-swatch" style="background:' + c + '"></div>'; }).join('');
      var badge = theme.isDark ? '<span class="dark-badge">暗色</span>' : '<span class="light-badge">亮色</span>';

      return '<div class="theme-card" data-slug="' + slug + '" data-dark="' + (theme.isDark ? '1' : '0') + '">'
        + '<div class="theme-card-name">' + escapeHtml(theme.name) + '</div>'
        + '<div class="theme-card-meta">@' + escapeHtml(meta.author || 'unknown') + ' ' + badge + '</div>'
        + '<div class="theme-card-palette">' + swatches + '</div>'
        + '<div class="theme-card-footer">'
        + '<div class="theme-card-actions">'
        + '<button class="theme-card-likes" data-slug="' + slug + '">'
        + '<svg viewBox="0 0 24 24" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>'
        + '<span class="reaction-count" data-slug="' + slug + '">0</span>'
        + '</button>'
        + '<button class="theme-card-fav favorited" data-slug="' + slug + '" onclick="toggleFavorite(\'' + slug + '\')" title="取消收藏">'
        + '<svg viewBox="0 0 24 24" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>'
        + '</button>'
        + '</div></div></div>';
    }

    // Popup (same as themes list)
    var popup = document.getElementById('theme-popup');
    var popupKb = document.getElementById('theme-popup-kb');
    var popupName = document.getElementById('theme-popup-name');
    var popupDetail = document.getElementById('popup-detail');
    var popupDownload = document.getElementById('popup-download');
    var popupCopy = document.getElementById('popup-copy');
    var popupClose = document.getElementById('theme-popup-close');
    var currentPopupSlug = '';

    function showPopup(slug, cardEl) {
      if (typeof window.renderKeyboard !== 'function' || !themes[slug]) return;
      currentPopupSlug = slug;
      var theme = themes[slug];
      popupKb.innerHTML = window.renderKeyboard(theme, layout, { keyHGap: 5, keyVGap: 5, keyRadius: 8, borderEnabled: false, isDark: theme.isDark });
      popupName.textContent = theme.name;
      popupDetail.href = base + '/theme/' + slug;
      if (window.innerWidth <= 768) {
        popup.classList.add('mobile-sheet');
        document.body.style.overflow = 'hidden';
        popup.style.display = 'block';
      } else {
        popup.classList.remove('mobile-sheet');
        popup.style.display = 'block';
        var rect = cardEl.getBoundingClientRect();
        var pr = popup.getBoundingClientRect();
        var top = rect.top - pr.height - 12;
        if (top < 8) top = 8;
        var left = rect.left + (rect.width - pr.width) / 2;
        left = Math.max(8, Math.min(left, window.innerWidth - pr.width - 8));
        popup.style.top = top + 'px';
        popup.style.left = left + 'px';
      }
    }

    function closePopup() {
      popup.style.display = 'none';
      popup.classList.remove('mobile-sheet');
      document.body.style.overflow = '';
      currentPopupSlug = '';
    }

    popupClose.addEventListener('click', closePopup);
    document.addEventListener('click', function(e) {
      if (currentPopupSlug && !popup.contains(e.target) && !e.target.closest('.theme-card')) closePopup();
    });

    popupDownload.addEventListener('click', function() {
      if (!themes[currentPopupSlug] || typeof JSZip === 'undefined') return;
      var zip = new JSZip();
      zip.file(currentPopupSlug + '.json', JSON.stringify(themes[currentPopupSlug], null, 2));
      zip.generateAsync({ type: 'blob' }).then(function(blob) {
        var url = URL.createObjectURL(blob);
        var a = document.createElement('a'); a.href = url; a.download = currentPopupSlug + '.zip'; a.click();
        URL.revokeObjectURL(url);
      });
    });

    popupCopy.addEventListener('click', function() {
      if (!themes[currentPopupSlug]) return;
      navigator.clipboard.writeText(JSON.stringify(themes[currentPopupSlug], null, 2)).then(function() {
        popupCopy.textContent = '已复制';
        setTimeout(function() { popupCopy.textContent = '复制 JSON'; }, 2000);
      });
    });

    // QR
    var qrModal = document.getElementById('qr-modal');
    var qrClose = document.getElementById('qr-modal-close');
    var qrCodeEl = document.getElementById('qr-code');
    var qrFilename = document.getElementById('qr-filename');
    var popupQr = document.getElementById('popup-qr');
    var qrDataCache = null;

    function showQrModal(slug) {
      if (!qrModal) return;
      qrModal.style.display = 'flex';
      document.body.style.overflow = 'hidden';
      qrCodeEl.innerHTML = '<p style="color:var(--text-sub)">加载中…</p>';
      qrFilename.textContent = '';
      function renderQr(data) {
        var s = data[slug];
        if (!s) { qrCodeEl.innerHTML = '<p style="color:var(--text-sub)">该主题暂无二维码</p>'; return; }
        if (typeof qrcode !== 'undefined') {
          var qr = qrcode(0, 'M'); qr.addData(s); qr.make();
          qrCodeEl.innerHTML = qr.createSvgTag({ cellSize: 4, margin: 4 });
          var svg = qrCodeEl.querySelector('svg');
          if (svg) { svg.setAttribute('width', '100%'); svg.setAttribute('height', '100%'); }
        }
        qrFilename.textContent = slug + '.json';
      }
      if (qrDataCache) { renderQr(qrDataCache); } else {
        fetch(base + '/qr-data.json').then(function(r) { return r.json(); })
          .then(function(data) { qrDataCache = data; renderQr(data); })
          .catch(function() { qrCodeEl.innerHTML = '<p style="color:var(--text-sub)">加载失败</p>'; });
      }
    }
    function closeQrModal() { if (qrModal) { qrModal.style.display = 'none'; document.body.style.overflow = ''; } }
    if (popupQr) popupQr.addEventListener('click', function() { if (currentPopupSlug) showQrModal(currentPopupSlug); });
    if (qrClose) qrClose.addEventListener('click', closeQrModal);
    if (qrModal) qrModal.addEventListener('click', function(e) { if (e.target === qrModal) closeQrModal(); });

    // --- Load favorites via Worker API ---
    function loadFavorites() {
      var token = window.getGitHubToken && window.getGitHubToken();
      if (!token) {
        document.getElementById('fav-login-prompt').style.display = 'block';
        return;
      }

      document.getElementById('fav-loading').style.display = 'block';

      fetch(API_BASE + '/api/user/reactions', {
        headers: { 'Authorization': 'token ' + token, 'Accept': 'application/json' },
      })
      .then(function(res) {
        if (!res.ok) throw new Error('Failed');
        return res.json();
      })
      .then(function(data) {
        document.getElementById('fav-loading').style.display = 'none';
        var favSlugs = data.favorites || [];
        if (favSlugs.length === 0) {
          document.getElementById('fav-empty').style.display = 'block';
          document.getElementById('fav-status').textContent = '暂无收藏';
          return;
        }

        var grid = document.getElementById('fav-grid');
        grid.innerHTML = favSlugs.filter(function(s) { return themes[s]; }).map(function(slug) {
          return renderCard(slug, themes[slug]);
        }).join('');
        grid.style.display = 'grid';
        document.getElementById('fav-status').textContent = '共 ' + favSlugs.length + ' 个收藏主题';

        // Bind interactions
        grid.querySelectorAll('.theme-card').forEach(function(card) {
          card.addEventListener('click', function(e) {
            if (e.target.closest('button') || e.target.closest('a')) return;
            showPopup(card.dataset.slug, card);
          });

          // Handle un-favorite
          var favBtn = card.querySelector('.theme-card-fav');
          if (favBtn) {
            favBtn.addEventListener('click', function() {
              window.toggleFavorite(card.dataset.slug);
              setTimeout(function() {
                if (!favBtn.classList.contains('favorited')) {
                  card.style.transition = 'opacity 0.3s, transform 0.3s';
                  card.style.opacity = '0';
                  card.style.transform = 'scale(0.9)';
                  setTimeout(function() {
                    card.remove();
                    var remaining = grid.querySelectorAll('.theme-card');
                    if (remaining.length === 0) {
                      document.getElementById('fav-empty').style.display = 'block';
                      grid.style.display = 'none';
                    }
                    document.getElementById('fav-status').textContent = '共 ' + remaining.length + ' 个收藏主题';
                  }, 300);
                }
              }, 500);
            });
          }
        });

        // Load counts for displayed cards
        if (typeof window.fetchAllReactions === 'function') {
          window.fetchAllReactions(favSlugs).then(function(counts) {
            favSlugs.forEach(function(slug) {
              var d = counts[slug];
              if (!d) return;
              var el = grid.querySelector('.reaction-count[data-slug="' + slug + '"]');
              if (el) el.textContent = d.likes || 0;
            });
          });
        }
      })
      .catch(function() {
        document.getElementById('fav-loading').style.display = 'none';
        document.getElementById('fav-empty').style.display = 'block';
        document.getElementById('fav-status').textContent = '加载失败';
      });
    }

    document.addEventListener('DOMContentLoaded', function() {
      setTimeout(function() {
        var token = window.getGitHubToken && window.getGitHubToken();
        if (token) loadFavorites();
        else document.getElementById('fav-login-prompt').style.display = 'block';
      }, 200);
    });
  </script>

  <style>
    .fav-login-prompt { text-align: center; padding: 60px 20px; }
    .fav-login-prompt p { font-size: 15px; color: var(--text-sub); margin-bottom: 20px; }
    .fav-loading { text-align: center; padding: 60px 20px; color: var(--text-sub); }
    .fav-empty { text-align: center; padding: 60px 20px; }
    .fav-empty svg { margin-bottom: 16px; }
    .fav-empty p { font-size: 15px; color: var(--text-sub); margin-bottom: 20px; }
  </style>
</Layout>
