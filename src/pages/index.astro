---
import Layout from '../layouts/Layout.astro';
import KeyboardPreview from '../components/KeyboardPreview.astro';
import { readdirSync, readFileSync } from 'fs';
import { join } from 'path';

const themesDir = join(process.cwd(), 'src/content/themes');
const files = readdirSync(themesDir).filter(f => f.endsWith('.json'));

interface Theme {
  name: string;
  author: string;
  isDark: boolean;
  builtin?: boolean;
  colors: Record<string, string>;
}

const themes: { slug: string; theme: Theme }[] = files.map(f => {
  const slug = f.replace('.json', '');
  const data = JSON.parse(readFileSync(join(themesDir, f), 'utf-8'));
  return { slug, theme: data as Theme };
});

const defaultTheme = themes.find(t => t.theme.isDark)?.theme || themes[0].theme;
const defaultSlug = themes.find(t => t.theme.isDark)?.slug || themes[0].slug;

const layoutData = JSON.parse(readFileSync(join(process.cwd(), 'src/data/default-layout.json'), 'utf-8'));
const themesJson = JSON.stringify(Object.fromEntries(themes.map(t => [t.slug, t.theme])));
const layoutJson = JSON.stringify(layoutData.default);

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title="f5a-gallery">
  <div class="container">
    <header class="site-header">
      <h1>f5a-gallery</h1>
      <p>fcitx5-android 键盘主题画廊</p>
    </header>

    <div class="preview-section">
      <div class="preview-label" id="preview-theme-name">{defaultTheme.name}</div>
      <div class="preview-layout">
        <div id="keyboard-container">
          <KeyboardPreview colors={defaultTheme.colors} />
        </div>
        <div class="color-legend" id="color-legend">
          <span class="legend-chip" id="legend-comment" style={`background:${defaultTheme.colors.candidateCommentColor}`}>候选注释</span>
          <span class="legend-chip" id="legend-popup" style={`background:${defaultTheme.colors.popupTextColor}`}>弹出文字</span>
          <span class="legend-chip" id="legend-clipboard" style={`background:${defaultTheme.colors.clipboardEntryColor}`}>剪贴板项</span>
          <span class="legend-chip" id="legend-active" style={`background:${defaultTheme.colors.genericActiveForegroundColor}`}>激活态</span>
        </div>
      </div>
    </div>

    <div class="theme-grid">
      {themes.map(({ slug, theme }) => {
        const cardBg = theme.colors.keyboardColor || theme.colors.backgroundColor;
        const textColor = theme.isDark ? '#ffffff' : '#1a1a1a';
        const barColor = theme.colors.altKeyBackgroundColor || theme.colors.barColor;
        const dotColor = theme.colors.accentKeyBackgroundColor;

        return (
          <div
            class={`theme-card${slug === defaultSlug ? ' active' : ''}`}
            data-slug={slug}
            style={`background:${cardBg};color:${textColor};border-color:${theme.isDark ? '#3a3d4a' : '#d0d0d0'}`}
          >
            <div class="theme-card-name">{theme.name}</div>
            <div class="theme-card-bar" style={`background:${barColor}`}></div>
            <div class="theme-card-meta">
              @{theme.author}
              {theme.builtin && <span class="builtin-badge">内置</span>}
            </div>
            <div class="theme-card-dot" style={`background:${dotColor}`}></div>
          </div>
        );
      })}
    </div>
  </div>

  <script define:vars={{ themesJson, layoutJson, defaultSlug }}>
    var themes = JSON.parse(themesJson);
    var layout = JSON.parse(layoutJson);

    function updateLegend(colors) {
      var map = {
        'legend-comment': colors.candidateCommentColor,
        'legend-popup': colors.popupTextColor,
        'legend-clipboard': colors.clipboardEntryColor,
        'legend-active': colors.genericActiveForegroundColor
      };
      Object.keys(map).forEach(function (id) {
        var el = document.getElementById(id);
        if (el) el.style.background = map[id];
      });
    }

    function updateKeyboard(slug) {
      if (!themes[slug]) return;
      var theme = themes[slug];
      var html = window.renderKeyboard(theme.colors, layout, {
        keyHGap: 3, keyVGap: 3, keyRadius: 4, borderEnabled: true
      });
      document.getElementById('keyboard-container').innerHTML = html;
      document.getElementById('preview-theme-name').textContent = theme.name;
      updateLegend(theme.colors);

      document.querySelectorAll('.theme-card').forEach(function (card) {
        card.classList.toggle('active', card.dataset.slug === slug);
      });
    }

    document.querySelectorAll('.theme-card').forEach(function (card) {
      card.addEventListener('click', function () {
        updateKeyboard(card.dataset.slug);
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    });
  </script>

  <style>
    .preview-label {
      text-align: center;
      font-size: 13px;
      color: var(--text-sub);
      margin-bottom: 8px;
      font-weight: 500;
    }

    .preview-layout {
      display: flex;
      gap: 24px;
      align-items: flex-start;
      justify-content: center;
    }

    #keyboard-container {
      flex: 1;
      max-width: 640px;
      min-width: 0;
    }

    /* Legend: colored chip badges */
    .color-legend {
      display: flex;
      flex-direction: column;
      gap: 6px;
      flex-shrink: 0;
      padding-top: 4px;
    }

    .legend-chip {
      display: inline-block;
      padding: 4px 10px;
      border-radius: 4px;
      font-size: 11px;
      font-weight: 500;
      color: #fff;
      text-shadow: 0 1px 2px rgba(0,0,0,0.4);
      white-space: nowrap;
      line-height: 1.3;
    }

    /* Card interaction */
    .theme-card {
      cursor: pointer;
    }

    .theme-card.active {
      border-color: var(--accent) !important;
      box-shadow: 0 0 8px 1px rgba(79, 140, 255, 0.3);
    }

    .theme-card-meta {
      font-size: 11px;
      opacity: 0.65;
      margin-top: auto;
      padding-top: 4px;
    }

    .theme-card-meta :global(.builtin-badge) {
      opacity: 1;
    }

    /* Mobile: legend below keyboard, horizontal wrap */
    @media (max-width: 640px) {
      .preview-layout {
        flex-direction: column;
        align-items: center;
      }

      .color-legend {
        flex-direction: row;
        flex-wrap: wrap;
        gap: 6px;
        justify-content: center;
      }
    }
  </style>
</Layout>
