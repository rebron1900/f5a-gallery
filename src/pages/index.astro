---
import Layout from '../layouts/Layout.astro';
import { readdirSync, readFileSync } from 'fs';
import { join } from 'path';
import { renderKeyboard, type ThemeColors } from '../scripts/keyboard-renderer';
import defaultLayout from '../data/default-layout.json';

const themesDir = join(process.cwd(), 'src/content/themes');
const files = readdirSync(themesDir).filter(f => f.endsWith('.json'));

interface Theme {
  name: string;
  author: string;
  isDark: boolean;
  builtin?: boolean;
  colors: ThemeColors;
}

const themes: { slug: string; theme: Theme; keyboardHtml: string }[] = files.map(f => {
  const slug = f.replace('.json', '');
  const data = JSON.parse(readFileSync(join(themesDir, f), 'utf-8'));
  const theme = data as Theme;
  const keyboardHtml = renderKeyboard(theme.colors, defaultLayout.default, {
    keyHGap: 1.5,
    keyVGap: 1.5,
    keyRadius: 3,
    borderEnabled: true,
  });
  return { slug, theme, keyboardHtml };
});

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title="f5a-gallery">
  <div class="container">
    <header class="site-header">
      <h1>f5a-gallery</h1>
      <p>fcitx5-android 键盘主题画廊</p>
    </header>

    <div class="theme-grid">
      {themes.map(({ slug, theme, keyboardHtml }) => {
        const accentColor = theme.colors.accentKeyBackgroundColor;
        return (
          <a href={`${base}/theme/${slug}`} class="theme-card">
            <div class="theme-card-keyboard" style={`background:${theme.colors.keyboardColor}`} set:html={keyboardHtml} />
            <div class="theme-card-footer">
              <span class="theme-card-name">{theme.name}</span>
              <span class="theme-card-dot" style={`background:${accentColor}`}></span>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</Layout>
