---
import Layout from '../layouts/Layout.astro';
import KeyboardPreview from '../components/KeyboardPreview.astro';
import { readdirSync, readFileSync } from 'fs';
import { join } from 'path';

const themesDir = join(process.cwd(), 'src/content/themes');
const files = readdirSync(themesDir).filter(f => f.endsWith('.json'));

interface Theme {
  name: string;
  author: string;
  isDark: boolean;
  builtin?: boolean;
  [key: string]: any;
}

function int32ToCSS(n: number): string {
  const u = n >= 0 ? n : n + 0x100000000;
  return '#' + ((u >> 16) & 0xff).toString(16).padStart(2, '0') + ((u >> 8) & 0xff).toString(16).padStart(2, '0') + (u & 0xff).toString(16).padStart(2, '0');
}

const themes: { slug: string; theme: Theme }[] = files.map(f => {
  const slug = f.replace('.json', '');
  const data = JSON.parse(readFileSync(join(themesDir, f), 'utf-8'));
  return { slug, theme: data as Theme };
});

const defaultTheme = themes.find(t => t.theme.isDark)?.theme || themes[0].theme;
const defaultSlug = themes.find(t => t.theme.isDark)?.slug || themes[0].slug;

const layoutData = JSON.parse(readFileSync(join(process.cwd(), 'src/data/default-layout.json'), 'utf-8'));
const themesJson = JSON.stringify(Object.fromEntries(themes.map(t => [t.slug, t.theme])));
const layoutJson = JSON.stringify(layoutData.default);

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Palette swatches for cards
const PALETTE_KEYS = ['backgroundColor', 'keyBackgroundColor', 'altKeyBackgroundColor', 'accentKeyBackgroundColor', 'keyTextColor'];
---

<Layout title="靓企鹅主题商店">
  <div class="container">

    <!-- ===== Hero Section ===== -->
    <section class="hero">
      <div class="hero-text">
        <h1 class="hero-title-sm">探索键盘主题</h1>
        <h2 class="hero-title">发现你的风格</h2>
        <p class="hero-desc">
          靓企鹅主题商店是 fcitx5-android-fx（靓企鹅版）键盘主题商店。<br/>
          浏览主题，实时预览键盘效果，<br/>
          找到最适合你的配色方案。
        </p>
        <div class="hero-actions">
          <a href="https://github.com/rebron1900/f5a-gallery/issues/new/choose" target="_blank" class="btn btn-primary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
            提交主题
          </a>
          <a href={`${base}/contributing`} class="btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
            查看指南
          </a>
        </div>
        <div class="hero-stats">
          <div class="stat-card">
            <div class="stat-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
            </div>
            <div class="stat-text">
              <div class="stat-value">{themes.length}</div>
              <div class="stat-label">主题</div>
            </div>
          </div>
          <div class="stat-card">
            <div class="stat-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
            </div>
            <div class="stat-text">
              <div class="stat-value">{new Set(themes.map(t => t.theme.author)).size}</div>
              <div class="stat-label">贡献者</div>
            </div>
          </div>
        </div>
      </div>

      <div class="hero-preview">
        <div class="preview-card">
          <div class="preview-title" id="preview-theme-name">{defaultTheme.name}</div>
          <div id="keyboard-container">
            <KeyboardPreview colors={defaultTheme} />
          </div>
          <div class="color-legend" id="color-legend">
            <span class="legend-chip">
              <span class="legend-dot" id="legend-popup" style={`background:${int32ToCSS(defaultTheme.popupTextColor)}`}></span>
              Popup
            </span>
            <span class="legend-chip">
              <span class="legend-dot" id="legend-clipboard" style={`background:${int32ToCSS(defaultTheme.clipboardEntryColor)}`}></span>
              Clipboard
            </span>
            <span class="legend-chip">
              <span class="legend-dot" id="legend-active" style={`background:${int32ToCSS(defaultTheme.genericActiveForegroundColor)}`}></span>
              Active
            </span>
            <span class="legend-chip">
              <span class="legend-dot" id="legend-comment" style={`background:${int32ToCSS(defaultTheme.candidateCommentColor)}`}></span>
              Comment
            </span>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== Theme Grid Section ===== -->
    <section class="themes-section">
      <div class="themes-header">
        <h2 class="section-title">主题色卡</h2>
        <a href={`${base}/themes`} class="themes-view-all">查看全部 →</a>
      </div>

      <div class="theme-grid">
        {themes.slice(0, 20).map(({ slug, theme }, i) => {
          const palette = PALETTE_KEYS.map(k => int32ToCSS(theme[k]));
          return (
            <div
              class={`theme-card${slug === defaultSlug ? ' active' : ''}`}
              data-slug={slug}
            >
              <div class="theme-card-name">{theme.name}</div>
              <div class="theme-card-meta">#{i + 1} · @{theme.author}</div>
              <div class="theme-card-palette">
                {palette.map(c => <div class="theme-card-swatch" style={`background:${c}`}></div>)}
              </div>
              <div class="theme-card-footer">
                <div class="theme-card-likes">
                  <svg viewBox="0 0 24 24" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
                  0
                </div>
                {theme.builtin && <span class="builtin-badge">内置</span>}
              </div>
            </div>
          );
        })}
      </div>

      {themes.length > 20 && (
        <div class="themes-more">
          <a href={`${base}/themes`} class="btn">查看更多主题 ({themes.length})</a>
        </div>
      )}
    </section>

    <!-- Theme Preview Popup (positioned by JS) -->
    <div class="theme-popup" id="theme-popup">
      <button class="theme-popup-close" id="theme-popup-close" aria-label="关闭">✕</button>
      <div class="theme-popup-name" id="theme-popup-name"></div>
      <div class="theme-popup-kb" id="theme-popup-kb"></div>
      <div class="theme-popup-actions">
        <button class="btn btn-sm" id="popup-download">下载 ZIP</button>
        <button class="btn btn-sm" id="popup-copy">复制 JSON</button>
        <button class="btn btn-sm" id="popup-qr">扫码</button>
        <a class="btn btn-primary btn-sm" id="popup-detail" href="#">详情</a>
      </div>
    </div>

    <!-- QR Modal -->
    <div class="qr-modal" id="qr-modal" style="display:none;">
      <div class="qr-modal-content">
        <button class="qr-modal-close" id="qr-modal-close" aria-label="关闭">✕</button>
        <h3>扫码导入主题</h3>
        <p>使用靓企鹅扫描下方二维码</p>
        <div class="qr-code" id="qr-code"></div>
        <p class="qr-filename" id="qr-filename"></p>
      </div>
    </div>

    <!-- ===== Bottom CTA (mobile) ===== -->
    <div class="hero-actions hero-actions-bottom">
      <a href="https://github.com/rebron1900/f5a-gallery/issues/new/choose" target="_blank" class="btn">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
        提交主题
      </a>
      <a href={`${base}/contributing`} class="btn btn-primary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
        查看指南
      </a>
    </div>

    <!-- ===== Footer ===== -->
    <footer class="site-footer">
      <div class="footer-grid">
        <div class="footer-col">
          <h3>关于 靓企鹅主题商店</h3>
          <p>开源的 fcitx5-android-fx（靓企鹅版）键盘主题商店，由社区驱动，自动化部署。</p>
          <a href="https://github.com/rebron1900/f5a-gallery" target="_blank">GitHub 仓库 →</a>
        </div>
        <div class="footer-col">
          <h3>快速链接</h3>
          <ul>
            <li><a href={base + '/contributing'}>主题提交指南</a></li>
            <li><a href={base + '/contributing'}>JSON 格式说明</a></li>
            <li><a href={base + '/contributing'}>贡献指南</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h3>技术栈</h3>
          <ul>
            <li>Astro SSG</li>
            <li>GitHub Actions</li>
            <li>GitHub Pages</li>
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg> 靓企鹅主题商店
      </div>
    </footer>

  </div>

  <script define:vars={{ themesJson, layoutJson, defaultSlug }}>
    var themes = JSON.parse(themesJson);
    var layout = JSON.parse(layoutJson);

    function updateLegend(theme) {
      var map = {
        'legend-popup': int32ToCSS(theme.popupTextColor),
        'legend-clipboard': int32ToCSS(theme.clipboardEntryColor),
        'legend-active': int32ToCSS(theme.genericActiveForegroundColor),
        'legend-comment': int32ToCSS(theme.candidateCommentColor)
      };
      Object.keys(map).forEach(function (id) {
        var el = document.getElementById(id);
        if (el) el.style.background = map[id];
      });
    }

    function updateKeyboard(slug) {
      if (typeof window.renderKeyboard !== 'function') return;
      if (!themes[slug]) return;
      var theme = themes[slug];
      var html = window.renderKeyboard(theme, layout, {
        keyHGap: 3, keyVGap: 3, keyRadius: 4, borderEnabled: true
      });
      document.getElementById('keyboard-container').innerHTML = html;
      document.getElementById('preview-theme-name').textContent = theme.name;
      updateLegend(theme);

      document.querySelectorAll('.theme-card').forEach(function (card) {
        card.classList.toggle('active', card.dataset.slug === slug);
      });
    }

    // --- Theme Popup ---
    var popup = document.getElementById('theme-popup');
    var popupKb = document.getElementById('theme-popup-kb');
    var popupName = document.getElementById('theme-popup-name');
    var popupDetail = document.getElementById('popup-detail');
    var popupDownload = document.getElementById('popup-download');
    var popupCopy = document.getElementById('popup-copy');
    var popupClose = document.getElementById('theme-popup-close');
    var currentPopupSlug = '';

    function showPopup(slug, cardEl) {
      if (typeof window.renderKeyboard !== 'function') return;
      if (!themes[slug]) return;
      currentPopupSlug = slug;
      var theme = themes[slug];
      var html = window.renderKeyboard(theme, layout, {
        keyHGap: 2, keyVGap: 2, keyRadius: 3, borderEnabled: true
      });
      popupKb.innerHTML = html;
      popupName.textContent = theme.name;
      popupDetail.href = base + '/theme/' + slug;
      // Position above the card
      var rect = cardEl.getBoundingClientRect();
      popup.style.display = 'block';
      var popupRect = popup.getBoundingClientRect();
      var top = rect.top - popupRect.height - 12;
      if (top < 8) top = 8;
      var left = rect.left + (rect.width - popupRect.width) / 2;
      left = Math.max(8, Math.min(left, window.innerWidth - popupRect.width - 8));
      popup.style.top = top + 'px';
      popup.style.left = left + 'px';
    }

    function closePopup() {
      popup.style.display = 'none';
      currentPopupSlug = '';
    }

    document.querySelectorAll('.theme-card').forEach(function (card) {
      card.addEventListener('click', function () {
        var slug = card.dataset.slug;
        updateKeyboard(slug);
        showPopup(slug, card);
      });
    });

    popupClose.addEventListener('click', closePopup);
    document.addEventListener('click', function(e) {
      if (currentPopupSlug && !popup.contains(e.target) && !e.target.closest('.theme-card')) {
        closePopup();
      }
    });
    popupDownload.addEventListener('click', function() {
      if (!themes[currentPopupSlug]) return;
      if (typeof JSZip === 'undefined') return;
      var json = JSON.stringify(themes[currentPopupSlug], null, 2);
      var zip = new JSZip();
      zip.file(currentPopupSlug + '.json', json);
      zip.generateAsync({ type: 'blob' }).then(function(blob) {
        var url = URL.createObjectURL(blob);
        var a = document.createElement('a');
        a.href = url;
        a.download = currentPopupSlug + '.zip';
        a.click();
        URL.revokeObjectURL(url);
      });
    });

    popupCopy.addEventListener('click', function() {
      if (!themes[currentPopupSlug]) return;
      var json = JSON.stringify(themes[currentPopupSlug], null, 2);
      navigator.clipboard.writeText(json).then(function() {
        popupCopy.textContent = '已复制';
        setTimeout(function() { popupCopy.textContent = '复制 JSON'; }, 2000);
      }).catch(function() {
        var ta = document.createElement('textarea');
        ta.value = json;
        ta.style.position = 'fixed';
        ta.style.opacity = '0';
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        document.body.removeChild(ta);
        popupCopy.textContent = '已复制';
        setTimeout(function() { popupCopy.textContent = '复制 JSON'; }, 2000);
      });
    });

    // QR code for 靓企鹅 import
    var qrModal = document.getElementById('qr-modal');
    var qrClose = document.getElementById('qr-modal-close');
    var qrCodeEl = document.getElementById('qr-code');
    var qrFilename = document.getElementById('qr-filename');
    var popupQr = document.getElementById('popup-qr');
    var qrDataCache = null;

    function showQrModal(slug) {
      qrModal.style.display = 'flex';
      qrCodeEl.innerHTML = '<p style="color:var(--text-sub)">加载中…</p>';
      qrFilename.textContent = '';

      function renderQr(data) {
        var qrStr = data[slug];
        if (!qrStr) {
          qrCodeEl.innerHTML = '<p style="color:var(--text-sub)">该主题暂无二维码</p>';
          return;
        }
        if (typeof qrcode !== 'undefined') {
          var qr = qrcode(0, 'M');
          qr.addData(qrStr);
          qr.make();
          qrCodeEl.innerHTML = qr.createSvgTag({ cellSize: 4, margin: 4 });
        } else {
          qrCodeEl.innerHTML = '<p style="color:var(--text-sub)">QR 库加载失败</p>';
        }
        qrFilename.textContent = slug + '.json';
      }

      if (qrDataCache) {
        renderQr(qrDataCache);
      } else {
        fetch(base + '/qr-data.json')
          .then(function(r) { return r.json(); })
          .then(function(data) { qrDataCache = data; renderQr(data); })
          .catch(function() { qrCodeEl.innerHTML = '<p style="color:var(--text-sub)">加载失败</p>'; });
      }
    }

    popupQr.addEventListener('click', function() {
      if (!currentPopupSlug) return;
      showQrModal(currentPopupSlug);
    });

    qrClose.addEventListener('click', function() {
      qrModal.style.display = 'none';
    });
    qrModal.addEventListener('click', function(e) {
      if (e.target === qrModal) qrModal.style.display = 'none';
    });
  </script>

  <style>
    /* ===== Hero ===== */
    .hero {
      display: flex;
      gap: 32px;
      align-items: flex-start;
      padding: 24px 0 32px;
    }

    .hero-text {
      flex: 1;
      min-width: 0;
    }

    .hero-title-sm {
      font-size: 18px;
      font-weight: 600;
      color: var(--text-secondary);
      margin-bottom: 2px;
    }

    .hero-title {
      font-size: 32px;
      font-weight: 700;
      color: var(--text-primary);
      margin-bottom: 12px;
      letter-spacing: -0.02em;
    }

    .hero-desc {
      font-size: 14px;
      color: var(--text-sub);
      line-height: 1.6;
      margin-bottom: 16px;
    }

    .hero-actions {
      display: flex;
      gap: 12px;
      margin-bottom: 20px;
    }

    /* Stats */
    .hero-stats {
      display: flex;
      gap: 12px;
    }

    .stat-card {
      flex: 1;
      background: var(--bg-white);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 10px 14px;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .stat-icon {
      color: var(--green-mid);
      display: flex;
      align-items: center;
      flex-shrink: 0;
    }

    .stat-text {
      display: flex;
      flex-direction: column;
    }

    .stat-value {
      font-size: 22px;
      font-weight: 700;
      color: var(--text-primary);
      line-height: 1.2;
    }

    .stat-label {
      font-size: 11px;
      color: var(--text-sub);
      opacity: 0.7;
    }

    /* Preview Card */
    .hero-preview {
      flex: 1.1;
      min-width: 0;
      margin: auto 0;
    }

    .preview-card {
      background: var(--bg-white);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      padding: 16px;
      box-shadow: var(--shadow-sm);
    }

    .preview-title {
      font-size: 13px;
      color: var(--text-sub);
      margin-bottom: 8px;
      font-weight: 500;
    }

    /* Legend */
    .color-legend {
      display: flex;
      gap: 12px;
      margin-top: 12px;
      flex-wrap: wrap;
      justify-content: center;
    }

    .legend-chip {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 12px;
      color: var(--text-sub);
      font-weight: 500;
    }

    .legend-dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      display: inline-block;
      border: 1px solid var(--border);
    }

    /* ===== Themes Section ===== */
    .themes-section {
      padding-bottom: 48px;
    }

    .themes-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 20px;
    }

    .themes-view-all {
      font-size: 14px;
      color: var(--green-mid);
      font-weight: 500;
    }



    /* ===== View More ===== */
    .themes-more {
      text-align: center;
      padding: 24px 0 0;
    }


    /* ===== Footer ===== */
    .site-footer {
      background: var(--bg-footer);
      border-radius: var(--radius-lg) var(--radius-lg) 0 0;
      padding: 40px 24px 24px;
      margin-top: 40px;
    }

    .footer-grid {
      display: flex;
      gap: 48px;
      margin-bottom: 32px;
    }

    .footer-col h3 {
      font-size: 15px;
      font-weight: 600;
      color: var(--text-primary);
      margin-bottom: 12px;
    }

    .footer-col p {
      font-size: 13px;
      color: var(--text-body);
      line-height: 1.7;
      margin-bottom: 8px;
    }

    .footer-col a {
      font-size: 13px;
      color: var(--green-mid);
    }

    .footer-col ul {
      list-style: none;
      margin: 0;
      padding: 0;
    }

    .footer-col li {
      font-size: 13px;
      color: var(--text-body);
      padding: 3px 0;
    }

    .footer-col li a {
      color: var(--text-body);
    }

    .footer-col li a:hover {
      color: var(--green-mid);
    }

    .footer-bottom {
      text-align: center;
      font-size: 12px;
      color: var(--text-sub);
      border-top: 1px solid var(--border);
      padding-top: 20px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 12px;
    }

    /* Mobile: buttons at bottom */
    .hero-actions-bottom {
      display: none;
      padding: 0 0 32px;
    }

    /* ===== Mobile ===== */
    @media (max-width: 768px) {
      .hero {
        flex-direction: column;
        gap: 12px;
        padding: 12px 0 20px;
      }

      .hero-title { font-size: 24px; margin-bottom: 6px; }
      .hero-desc { margin-bottom: 12px; line-height: 1.6; font-size: 13px; }

      .hero-preview { width: 100%; }

      .hero-stats {
        flex-direction: row;
        gap: 8px;
      }

      .stat-card { padding: 8px 10px; gap: 8px; }
      .stat-value { font-size: 20px; }

      .hero-actions-bottom {
        display: flex;
        gap: 12px;
        justify-content: center;
        flex-wrap: wrap;
      }

      .preview-card { padding: 12px; }

      .themes-section { padding-bottom: 32px; }

      .themes-header {
        flex-direction: row;
        align-items: center;
      }

      .theme-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 12px;
      }

      .footer-grid {
        flex-direction: column;
        gap: 24px;
        margin-bottom: 32px;
      }

      .footer-bottom {
        /* padding handled by .container */
      }

      .theme-popup { padding: 16px; max-width: 100%; }
      .theme-popup-actions { flex-wrap: wrap; }
    }

    @media (max-width: 480px) {
      .hero { gap: 8px; padding: 8px 0 16px; }
      .hero-title { font-size: 22px; }
      .hero-title-sm { font-size: 15px; }
      .hero-desc { font-size: 12px; margin-bottom: 10px; }

      .stat-card { padding: 6px 8px; gap: 6px; }
      .stat-value { font-size: 18px; }
