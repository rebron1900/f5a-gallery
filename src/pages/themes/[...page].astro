---
import Layout from '../../layouts/Layout.astro';
import { readdirSync, readFileSync } from 'fs';
import { join } from 'path';

export function getStaticPaths({ paginate }) {
  const themesDir = join(process.cwd(), 'src/content/themes');
  const files = readdirSync(themesDir).filter(f => f.endsWith('.json'));

  interface Theme {
    name: string;
    author: string;
    isDark: boolean;
    builtin?: boolean;
    [key: string]: any;
  }

  const themes: { slug: string; theme: Theme }[] = files.map(f => {
    const slug = f.replace('.json', '');
    const data = JSON.parse(readFileSync(join(themesDir, f), 'utf-8'));
    return { slug, theme: data as Theme };
  });

  // Sort alphabetically for stable pagination
  themes.sort((a, b) => a.slug.localeCompare(b.slug));

  return paginate(themes, { pageSize: 20 });
}

const { page } = Astro.props;
const themes = page.data;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Palette swatches for cards
const PALETTE_KEYS = ['backgroundColor', 'keyBackgroundColor', 'altKeyBackgroundColor', 'accentKeyBackgroundColor', 'keyTextColor'];
function int32ToCSS(n: number): string {
  const u = n >= 0 ? n : n + 0x100000000;
  return '#' + ((u >> 16) & 0xff).toString(16).padStart(2, '0') + ((u >> 8) & 0xff).toString(16).padStart(2, '0') + (u & 0xff).toString(16).padStart(2, '0');
}


function hexToHsl(hex: string): { h: number; s: number; l: number } | null {
  hex = hex.replace('#', '');
  if (hex.length === 3) hex = hex[0]+hex[0]+hex[1]+hex[1]+hex[2]+hex[2];
  const r = parseInt(hex.slice(0, 2), 16) / 255;
  const g = parseInt(hex.slice(2, 4), 16) / 255;
  const b = parseInt(hex.slice(4, 6), 16) / 255;
  const max = Math.max(r, g, b), min = Math.min(r, g, b);
  const l = (max + min) / 2;
  if (max === min) return { h: 0, s: 0, l };
  const d = max - min;
  const s = l > 0.5 ? d / (2 - max - min) : d / (max + min);
  let h = 0;
  if (max === r) h = ((g - b) / d + (g < b ? 6 : 0)) / 6;
  else if (max === g) h = ((b - r) / d + 2) / 6;
  else h = ((r - g) / d + 4) / 6;
  return { h: h * 360, s, l };
}

function getColorFamily(hex: string): string {
  const hsl = hexToHsl(hex);
  if (!hsl) return 'other';
  const { h, s, l } = hsl;
  if (l < 0.2) return 'dark';
  if (l > 0.8) return 'light';
  if (s < 0.1) return 'gray';
  if (h < 30 || h >= 330) return 'warm';
  if (h < 90) return 'yellow';
  if (h < 150) return 'green';
  if (h < 210) return 'cyan';
  if (h < 270) return 'blue';
  return 'purple';
}

const themeFamilies = themes.map(({ slug, theme }) => {
  const bg = int32ToCSS(theme.backgroundColor);
  return { slug, theme, family: getColorFamily(bg) };
});

const COLOR_FAMILIES = [
  { key: 'dark', label: '暗色系', dot: '#1a1a2e' },
  { key: 'light', label: '浅色系', dot: '#f0f0f0' },
  { key: 'gray', label: '灰色系', dot: '#888888' },
  { key: 'warm', label: '暖色系', dot: '#c0392b' },
  { key: 'yellow', label: '黄橙系', dot: '#f39c12' },
  { key: 'green', label: '绿色系', dot: '#27ae60' },
  { key: 'cyan', label: '青色系', dot: '#00838f' },
  { key: 'blue', label: '蓝紫系', dot: '#2980b9' },
  { key: 'purple', label: '紫色系', dot: '#8e44ad' },
];

const layoutData = JSON.parse(readFileSync(join(process.cwd(), 'src/data/default-layout.json'), 'utf-8'));
const themesJson = JSON.stringify(Object.fromEntries(themes.map(t => [t.slug, t.theme])));
const layoutJson = JSON.stringify(layoutData.default);

// Pagination URL helpers
const prevUrl = page.url.prev ? base + page.url.prev : null;
const nextUrl = page.url.next ? base + page.url.next : null;
const themesBase = base + '/themes';
---

<Layout title={page.currentPage > 1 ? `主题列表 (第${page.currentPage}页)` : '主题列表'}>
  <div class="container themes-page">

    <!-- Header -->
    <div class="themes-page-header">
      <div class="themes-page-title-row">
        <a href={base + '/'} class="back-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
          返回首页
        </a>
      </div>
      <h1>主题列表</h1>
      <p class="themes-page-sub">共 <strong>{page.total}</strong> 个主题，第 {page.currentPage} / {page.lastPage} 页</p>
    </div>

    <!-- Filter Bar -->
    <div class="filter-bar">
      <div class="filter-group">
        <span class="filter-label">模式</span>
        <div class="filter-toggles">
          <button class="filter-btn active" data-filter-type="mode" data-filter-value="all">全部</button>
          <button class="filter-btn" data-filter-type="mode" data-filter-value="light">亮色</button>
          <button class="filter-btn" data-filter-type="mode" data-filter-value="dark">暗色</button>
        </div>
      </div>
      <div class="filter-group">
        <span class="filter-label">色调</span>
        <div class="color-dots">
          <button class="color-dot active" data-filter-type="color" data-filter-value="all" title="全部">
            <span class="dot" style="background: conic-gradient(#c0392b, #f39c12, #27ae60, #2980b9, #8e44ad, #c0392b);"></span>
            <span class="dot-label">全部</span>
          </button>
          {COLOR_FAMILIES.map(f => (
            <button class="color-dot" data-filter-type="color" data-filter-value={f.key} title={f.label}>
              <span class="dot" style={`background:${f.dot}`}></span>
              <span class="dot-label">{f.label}</span>
            </button>
          ))}
        </div>
      </div>
      <div class="filter-count">
        显示 <span id="visible-count">{themes.length}</span> / {themes.length}
      </div>
    </div>

    <!-- Theme Grid -->
    <div class="theme-grid" id="theme-grid">
      {themeFamilies.map(({ slug, theme, family }) => {
        const palette = PALETTE_KEYS.map(k => int32ToCSS(theme[k]));
        return (
          <div
            class="theme-card"
            data-slug={slug}
            data-dark={theme.isDark ? '1' : '0'}
            data-family={family}
          >
            <div class="theme-card-name">{theme.name}</div>
            <div class="theme-card-meta">
              @{theme.author}
              {theme.isDark
                ? <span class="dark-badge">暗色</span>
                : <span class="light-badge">亮色</span>
              }
            </div>
            <div class="theme-card-palette">
              {palette.map(c => <div class="theme-card-swatch" style={`background:${c}`}></div>)}
            </div>
            <div class="theme-card-footer">
              <div class="theme-card-likes">
                <svg viewBox="0 0 24 24" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
                0
              </div>
              {theme.builtin && <span class="builtin-badge">内置</span>}
            </div>
          </div>
        );
      })}
    </div>

    <!-- Empty state (filter) -->
    <div class="empty-state" id="empty-state" style="display:none;">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--text-sub)" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <p>没有匹配的主题</p>
      <button class="btn" id="clear-filters">清除筛选</button>
    </div>

    <!-- Pagination -->
    {page.lastPage > 1 && (
      <nav class="pagination" aria-label="分页">
        {prevUrl ? (
          <a href={prevUrl} class="page-link">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
            上一页
          </a>
        ) : <span class="page-link disabled">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
            上一页
          </span>}

        <div class="page-numbers">
          {Array.from({ length: page.lastPage }, (_, i) => i + 1).map(n => (
            n === page.currentPage
              ? <span class="page-num active">{n}</span>
              : <a href={n === 1 ? themesBase : `${themesBase}/${n}`} class="page-num">{n}</a>
          ))}
        </div>

        {nextUrl ? (
          <a href={nextUrl} class="page-link">
            下一页
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
          </a>
        ) : <span class="page-link disabled">
            下一页
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
          </span>}
      </nav>
    )}

    <!-- Theme Preview Popup -->
    <div class="theme-popup" id="theme-popup">
      <button class="theme-popup-close" id="theme-popup-close" aria-label="关闭">✕</button>
      <div class="theme-popup-name" id="theme-popup-name"></div>
      <div class="theme-popup-kb" id="theme-popup-kb"></div>
      <div class="theme-popup-actions">
        <button class="btn btn-sm" id="popup-download">下载 ZIP</button>
        <button class="btn btn-sm" id="popup-copy">复制 JSON</button>
        <button class="btn btn-sm" id="popup-qr">扫码</button>
        <a class="btn btn-primary btn-sm" id="popup-detail" href="#">详情</a>
      </div>
    </div>

    <!-- QR Modal -->
    <div class="qr-modal" id="qr-modal" style="display:none;">
      <div class="qr-modal-content">
        <button class="qr-modal-close" id="qr-modal-close" aria-label="关闭">✕</button>
        <h3>扫码导入主题</h3>
        <p>使用靓企鹅扫描下方二维码</p>
        <div class="qr-code" id="qr-code"></div>
        <p class="qr-filename" id="qr-filename"></p>
      </div>
    </div>

  </div>

    <!-- ===== Footer ===== -->
    <footer class="site-footer">
      <div class="footer-grid">
        <div class="footer-col">
          <h3>关于 靓企鹅主题商店</h3>
          <p>开源的 fcitx5-android-fx（靓企鹅版）键盘主题商店，由社区驱动，自动化部署。</p>
          <a href="https://github.com/rebron1900/f5a-gallery" target="_blank">GitHub 仓库 →</a>
        </div>
        <div class="footer-col">
          <h3>快速链接</h3>
          <ul>
            <li><a href={base + '/contributing'}>主题提交指南</a></li>
            <li><a href={base + '/contributing'}>JSON 格式说明</a></li>
            <li><a href={base + '/contributing'}>贡献指南</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h3>技术栈</h3>
          <ul>
            <li>Astro SSG</li>
            <li>GitHub Actions</li>
            <li>GitHub Pages</li>
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg> 靓企鹅主题商店
      </div>
    </footer>

  </div>

  <script define:vars={{ themesJson, layoutJson, base }}>
    var themes = JSON.parse(themesJson);
    var layout = JSON.parse(layoutJson);
    var currentMode = 'all';
    var currentColor = 'all';
    var cards = document.querySelectorAll('.theme-card[data-slug]');
    var visibleCountEl = document.getElementById('visible-count');
    var emptyState = document.getElementById('empty-state');

    function applyFilters() {
      var visible = 0;
      cards.forEach(function (card) {
        var modeMatch = currentMode === 'all' ||
          (currentMode === 'dark' && card.dataset.dark === '1') ||
          (currentMode === 'light' && card.dataset.dark === '0');
        var colorMatch = currentColor === 'all' || card.dataset.family === currentColor;
        var show = modeMatch && colorMatch;
        card.style.display = show ? '' : 'none';
        if (show) visible++;
      });
      if (visibleCountEl) visibleCountEl.textContent = visible;
      if (emptyState) emptyState.style.display = visible === 0 ? '' : 'none';
    }

    document.querySelectorAll('[data-filter-type="mode"]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        document.querySelectorAll('[data-filter-type="mode"]').forEach(function (b) {
          b.classList.remove('active');
        });
        btn.classList.add('active');
        currentMode = btn.dataset.filterValue;
        applyFilters();
      });
    });

    document.querySelectorAll('[data-filter-type="color"]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        document.querySelectorAll('[data-filter-type="color"]').forEach(function (b) {
          b.classList.remove('active');
        });
        btn.classList.add('active');
        currentColor = btn.dataset.filterValue;
        applyFilters();
      });
    });

    var clearBtn = document.getElementById('clear-filters');
    if (clearBtn) {
      clearBtn.addEventListener('click', function () {
        currentMode = 'all';
        currentColor = 'all';
        document.querySelectorAll('.filter-btn, .color-dot').forEach(function (b) {
          b.classList.remove('active');
        });
        document.querySelector('[data-filter-value="all"][data-filter-type="mode"]').classList.add('active');
        document.querySelector('[data-filter-value="all"][data-filter-type="color"]').classList.add('active');
        applyFilters();
      });
    }

    // --- Theme Popup ---
    var popup = document.getElementById('theme-popup');
    var popupKb = document.getElementById('theme-popup-kb');
    var popupName = document.getElementById('theme-popup-name');
    var popupDetail = document.getElementById('popup-detail');
    var popupDownload = document.getElementById('popup-download');
    var popupCopy = document.getElementById('popup-copy');
    var popupClose = document.getElementById('theme-popup-close');
    var currentPopupSlug = '';

    function showPopup(slug, cardEl) {
      if (typeof window.renderKeyboard !== 'function') return;
      if (!themes[slug]) return;
      currentPopupSlug = slug;
      var theme = themes[slug];
      var html = window.renderKeyboard(theme, layout, {
        keyHGap: 2, keyVGap: 2, keyRadius: 3, borderEnabled: true
      });
      popupKb.innerHTML = html;
      popupName.textContent = theme.name;
      popupDetail.href = base + '/theme/' + slug;
      var rect = cardEl.getBoundingClientRect();
      popup.style.display = 'block';
      var popupRect = popup.getBoundingClientRect();
      var top = rect.top - popupRect.height - 12;
      if (top < 8) top = 8;
      var left = rect.left + (rect.width - popupRect.width) / 2;
      left = Math.max(8, Math.min(left, window.innerWidth - popupRect.width - 8));
      popup.style.top = top + 'px';
      popup.style.left = left + 'px';
    }

    function closePopup() {
      popup.style.display = 'none';
      currentPopupSlug = '';
    }

    cards.forEach(function (card) {
      card.addEventListener('click', function () {
        showPopup(card.dataset.slug, card);
      });
    });

    popupClose.addEventListener('click', closePopup);
    document.addEventListener('click', function(e) {
      if (currentPopupSlug && !popup.contains(e.target) && !e.target.closest('.theme-card')) {
        closePopup();
      }
    });

    popupDownload.addEventListener('click', function() {
      if (!themes[currentPopupSlug]) return;
      if (typeof JSZip === 'undefined') return;
      var json = JSON.stringify(themes[currentPopupSlug], null, 2);
      var zip = new JSZip();
      zip.file(currentPopupSlug + '.json', json);
      zip.generateAsync({ type: 'blob' }).then(function(blob) {
        var url = URL.createObjectURL(blob);
        var a = document.createElement('a');
        a.href = url;
        a.download = currentPopupSlug + '.zip';
        a.click();
        URL.revokeObjectURL(url);
      });
    });

    popupCopy.addEventListener('click', function() {
      if (!themes[currentPopupSlug]) return;
      var json = JSON.stringify(themes[currentPopupSlug], null, 2);
      navigator.clipboard.writeText(json).then(function() {
        popupCopy.textContent = '已复制';
        setTimeout(function() { popupCopy.textContent = '复制 JSON'; }, 2000);
      }).catch(function() {
        var ta = document.createElement('textarea');
        ta.value = json;
        ta.style.position = 'fixed';
        ta.style.opacity = '0';
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        document.body.removeChild(ta);
        popupCopy.textContent = '已复制';
        setTimeout(function() { popupCopy.textContent = '复制 JSON'; }, 2000);
      });
    });

    // QR code for 靓企鹅 import
    var qrModal = document.getElementById('qr-modal');
    var qrClose = document.getElementById('qr-modal-close');
    var qrCodeEl = document.getElementById('qr-code');
    var qrFilename = document.getElementById('qr-filename');
    var popupQr = document.getElementById('popup-qr');
    var qrDataCache = null;

    function showQrModal(slug) {
      qrModal.style.display = 'flex';
      qrCodeEl.innerHTML = '<p style="color:var(--text-sub)">加载中…</p>';
      qrFilename.textContent = '';

      function renderQr(data) {
        var qrStr = data[slug];
        if (!qrStr) {
          qrCodeEl.innerHTML = '<p style="color:var(--text-sub)">该主题暂无二维码</p>';
          return;
        }
        if (typeof qrcode !== 'undefined') {
          var qr = qrcode(0, 'M');
          qr.addData(qrStr);
          qr.make();
          qrCodeEl.innerHTML = qr.createSvgTag({ cellSize: 4, margin: 4 });
          var svg = qrCodeEl.querySelector('svg');
          if (svg) { svg.setAttribute('width', '100%'); svg.setAttribute('height', '100%'); }
        } else {
          qrCodeEl.innerHTML = '<p style="color:var(--text-sub)">QR 库加载失败</p>';
        }
        qrFilename.textContent = slug + '.json';
      }

      if (qrDataCache) {
        renderQr(qrDataCache);
      } else {
        fetch(base + '/qr-data.json')
          .then(function(r) { return r.json(); })
          .then(function(data) { qrDataCache = data; renderQr(data); })
          .catch(function() { qrCodeEl.innerHTML = '<p style="color:var(--text-sub)">加载失败</p>'; });
      }
    }

    popupQr.addEventListener('click', function() {
      if (!currentPopupSlug) return;
      showQrModal(currentPopupSlug);
    });

    qrClose.addEventListener('click', function() {
      qrModal.style.display = 'none';
    });
    qrModal.addEventListener('click', function(e) {
      if (e.target === qrModal) qrModal.style.display = 'none';
    });
  </script>

  <style>
    /* Page header */
    .themes-page {
      padding: 24px 32px 48px;
    }

    .themes-page-header {
      margin-bottom: 24px;
    }

    .themes-page-title-row {
      margin-bottom: 8px;
    }

    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      font-size: 14px;
      color: var(--text-sub);
      font-weight: 500;
    }
    .back-link:hover { color: var(--text-body); opacity: 1; }

    .themes-page-header h1 {
      font-size: 28px;
      font-weight: 700;
      color: var(--text-primary);
      margin-bottom: 4px;
    }

    .themes-page-sub {
      font-size: 14px;
      color: var(--text-sub);
    }

    .themes-page-sub strong {
      color: var(--text-primary);
    }

    /* Filter bar */
    .filter-bar {
      background: var(--bg-white);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 16px 20px;
      margin-bottom: 24px;
      display: flex;
      flex-wrap: wrap;
      gap: 20px;
      align-items: center;
    }

    .filter-group {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .filter-label {
      font-size: 13px;
      color: var(--text-sub);
      font-weight: 500;
      flex-shrink: 0;
    }

    .filter-toggles {
      display: flex;
      gap: 4px;
      background: var(--bg);
      border-radius: var(--radius-sm);
      padding: 3px;
    }

    .filter-btn {
      padding: 6px 14px;
      font-size: 13px;
      font-weight: 500;
      border: none;
      background: transparent;
      color: var(--text-sub);
      border-radius: var(--radius-sm);
      cursor: pointer;
      transition: all 0.15s;
    }

    .filter-btn:hover {
      color: var(--text-body);
    }

    .filter-btn.active {
      background: var(--bg-white);
      color: var(--text-primary);
      box-shadow: var(--shadow-sm);
    }

    .color-dots {
      display: flex;
      gap: 6px;
      flex-wrap: wrap;
      align-items: center;
    }

    .color-dot {
      display: flex;
      align-items: center;
      gap: 5px;
      padding: 4px 10px 4px 4px;
      border: 1.5px solid var(--border);
      border-radius: var(--radius-pill);
      background: var(--bg-white);
      cursor: pointer;
      transition: all 0.15s;
      font-size: 12px;
      color: var(--text-sub);
    }

    .color-dot:hover {
      border-color: var(--green-accent);
    }

    .color-dot.active {
      border-color: var(--green-mid);
      background: var(--green-pale);
      color: var(--text-primary);
    }

    .dot {
      width: 14px;
      height: 14px;
      border-radius: 50%;
      flex-shrink: 0;
      border: 1px solid rgba(0,0,0,0.08);
    }

    .dot-label {
      font-weight: 500;
    }

    .filter-count {
      margin-left: auto;
      font-size: 13px;
      color: var(--text-sub);
    }

    /* Badge variants */
    .dark-badge,
    .light-badge {
      display: inline-block;
      font-size: 10px;
      font-weight: 600;
      padding: 1px 6px;
      border-radius: 3px;
      margin-left: 6px;
      vertical-align: middle;
    }

    .dark-badge {
      background: rgba(60, 84, 64, 0.1);
      color: var(--green-mid);
    }

    .light-badge {
      background: rgba(243, 218, 156, 0.25);
      color: #a08030;
    }

    /* Empty state */
    .empty-state {
      text-align: center;
      padding: 64px 0;
    }

    .empty-state p {
      font-size: 15px;
      color: var(--text-sub);
      margin: 12px 0 16px;
    }

    /* Pagination */
    .pagination {
      display: flex;
      align-items: center;
      justify-content: center;
