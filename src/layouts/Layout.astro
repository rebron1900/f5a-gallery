---
import { readFileSync } from 'fs';
import { join } from 'path';

interface Props {
  title: string;
}

const { title } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Inline keyboard CSS to avoid FOUC on mobile
const keyboardCss = readFileSync(join(process.cwd(), 'public/styles/keyboard.css'), 'utf-8');
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | 小企鹅主题商店</title>
    <link rel="icon" type="image/png" href={`${base}/logo.png`} />
    <link rel="stylesheet" href={`${base}/styles/global.css`} />
    <style set:html={keyboardCss}></style>
  </head>
  <body>
    <div class="container">
      <nav class="site-nav">
        <a href={base + '/'} class="nav-logo">
          <img src={`${base}/logo.png`} alt="小企鹅主题商店" class="nav-logo-img" />
          小企鹅主题商店
        </a>
        <ul class="nav-links" id="nav-links">
          <li><a href={base + '/'}>首页</a></li>
          <li><a href={base + '/themes'}>主题列表</a></li>
          <li><a href="https://github.com/rebron1900/f5a-gallery/issues/new/choose" target="_blank">主题提交</a></li>
          <li><a href={base + '/about'}>关于项目</a></li>
          <li><a href={base + '/contributing'}>贡献指南</a></li>
        </ul>
        <div class="nav-right">
          <div id="github-login-area" class="nav-login">
            <button id="github-login-btn" class="nav-login-btn" onclick="loginWithGitHub()">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
              登录
            </button>
            <div id="github-user-info" class="nav-user-info" style="display:none;">
              <img id="github-avatar" width="24" height="24" style="border-radius:50%;" />
              <span id="github-username"></span>
              <button class="nav-logout-btn" onclick="logoutGitHub()">退出</button>
            </div>
          </div>
          <a href="https://github.com/rebron1900/f5a-gallery" target="_blank" class="nav-github">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
            GitHub
          </a>
          <button class="nav-hamburger" id="nav-hamburger" aria-label="菜单">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
          </button>
        </div>
      </nav>
    </div>

    <!-- Mobile menu overlay -->
    <div class="mobile-menu" id="mobile-menu">
      <div class="mobile-menu-header">
        <span class="mobile-menu-title">小企鹅主题商店</span>
        <button class="mobile-menu-close" id="mobile-menu-close" aria-label="关闭">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
      <ul class="mobile-menu-links">
        <li><a href={base + '/'}>首页</a></li>
        <li><a href={base + '/themes'}>主题列表</a></li>
        <li><a href="https://github.com/rebron1900/f5a-gallery/issues/new/choose" target="_blank">主题提交</a></li>
        <li><a href={base + '/about'}>关于项目</a></li>
        <li><a href={base + '/contributing'}>贡献指南</a></li>
        <li><a href="https://github.com/rebron1900/f5a-gallery" target="_blank">GitHub</a></li>
        <li id="mobile-login-area">
          <a href="#" onclick="loginWithGitHub();return false;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" style="vertical-align:middle;margin-right:4px;"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            GitHub 登录
          </a>
        </li>
      </ul>
    </div>

    <slot />

    <script is:inline src={`${base}/scripts/keyboard-render.js?v=3`}></script>
    <script is:inline src="https://cdn.jsdelivr.net/npm/jszip@3/dist/jszip.min.js"></script>
    <script is:inline src="https://cdn.jsdelivr.net/npm/qrcode-generator@1/qrcode.min.js"></script>
    <script is:inline>
      (function() {
        var hamburger = document.getElementById('nav-hamburger');
        var menu = document.getElementById('mobile-menu');
        var closeBtn = document.getElementById('mobile-menu-close');
        if (!hamburger || !menu || !closeBtn) return;

        hamburger.addEventListener('click', function() {
          menu.classList.add('open');
          document.body.style.overflow = 'hidden';
        });

        closeBtn.addEventListener('click', function() {
          menu.classList.remove('open');
          document.body.style.overflow = '';
        });

        menu.addEventListener('click', function(e) {
          if (e.target === menu) {
            menu.classList.remove('open');
            document.body.style.overflow = '';
          }
        });
      })();
    </script>

    <style>
      /* Mobile menu overlay */
      .mobile-menu {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: var(--bg-white);
        z-index: 1000;
        padding: 20px;
        flex-direction: column;
      }

      .mobile-menu.open {
        display: flex;
      }

      .mobile-menu-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 32px;
        padding-bottom: 16px;
        border-bottom: 1px solid var(--border);
      }

      .mobile-menu-title {
        font-size: 18px;
        font-weight: 700;
        color: var(--text-primary);
      }

      .mobile-menu-close {
        width: 36px;
        height: 36px;
        display: flex;
        align-items: center;
        justify-content: center;
        border: none;
        background: none;
        color: var(--text-body);
        cursor: pointer;
        border-radius: var(--radius-sm);
      }

      .mobile-menu-close:hover {
        background: var(--green-pale);
      }

      .mobile-menu-links {
        list-style: none;
        margin: 0;
        padding: 0;
      }

      .mobile-menu-links li {
        border-bottom: 1px solid var(--border);
      }

      .mobile-menu-links a {
        display: block;
        padding: 16px 4px;
        font-size: 16px;
        font-weight: 500;
        color: var(--text-body);
      }

      .mobile-menu-links a:hover {
        color: var(--green-mid);
      }

      /* Nav login */
      .nav-login {
        display: inline-flex;
        align-items: center;
        gap: 6px;
      }

      .nav-login-btn {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 5px 12px;
        font-size: 13px;
        font-weight: 500;
        color: #fff;
        background: #24292e;
        border: none;
        border-radius: 6px;
        cursor: pointer;
        transition: background 0.15s;
      }

      .nav-login-btn:hover {
        background: #444d56;
      }

      .nav-user-info {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 13px;
        color: var(--text-body);
      }

      .nav-user-info span {
        font-weight: 500;
        max-width: 100px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }

      .nav-logout-btn {
        padding: 3px 8px;
        font-size: 11px;
        color: var(--text-sub);
        background: none;
        border: 1px solid var(--border);
        border-radius: 4px;
        cursor: pointer;
      }

      .nav-logout-btn:hover {
        color: var(--text-body);
        border-color: var(--text-sub);
      }

      @media (max-width: 768px) {
        .nav-login { display: none; }
      }

    </style>
  </body>
</html>
