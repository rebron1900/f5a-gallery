---
interface Props {
  title: string;
}

const { title } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | f5a-gallery</title>
    <link rel="stylesheet" href={`${base}/styles/global.css`} />
    <link rel="stylesheet" href={`${base}/styles/keyboard.css`} />
  </head>
  <body>
    <slot />
    <script is:inline src={`${base}/scripts/keyboard-render.js`}></script>
  </body>
</html>
