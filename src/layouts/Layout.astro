---
import { readFileSync } from 'fs';
import { join } from 'path';

interface Props {
  title: string;
}

const { title } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Inline keyboard CSS to avoid FOUC on mobile (external CSS loading delay)
const keyboardCss = readFileSync(join(process.cwd(), 'public/styles/keyboard.css'), 'utf-8');
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | f5a-gallery</title>
    <link rel="stylesheet" href={`${base}/styles/global.css`} />
    <style set:html={keyboardCss}></style>
  </head>
  <body>
    <slot />
    <script is:inline src="https://unpkg.com/lucide@0.460.0/dist/umd/lucide.min.js"></script>
    <script is:inline src={`${base}/scripts/keyboard-render.js`}></script>
    <script is:inline>
      /* Initialize Lucide icons — runs once on load and after any dynamic re-render */
      function initLucideIcons() {
        if (typeof lucide !== 'undefined' && lucide.createIcons) {
          lucide.createIcons();
        }
      }
      document.addEventListener('DOMContentLoaded', initLucideIcons);
    </script>
  </body>
</html>
