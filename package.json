{
  "name": "f5a-gallery",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "validate": "npx tsx scripts/validate-theme.ts",
    "generate-zips": "node scripts/generate-zips.mjs",
    "prebuild": "python3 scripts/fix-theme-fields.py --apply && node scripts/generate-zips.mjs && python3 scripts/generate-qr-data.py && python3 scripts/fetch-reactions.py || true",
