    "fetch-reactions": "python3 scripts/fetch-reactions.py"
  },
  "dependencies": {
    "astro": "^6.4.6"
  },
  "devDependencies": {
    "jszip": "^3.10.1",
    "lzma": "^2.3.2",
    "tsx": "^4.22.4"
  }
}